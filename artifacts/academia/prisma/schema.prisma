generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum SubscriptionTier {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CHURNED
}

enum SchoolBoard {
  CBSE
  ICSE
  STATE_BOARD
  OTHER
}

enum UserRole {
  ADMIN
  FACULTY
  PRINCIPAL
  ACCOUNTANT
  PARENT
}

enum SystemRole {
  SUPER_ADMIN
  ADMIN
  HOD
  FACULTY
}

enum PermissionScope {
  GLOBAL
  SCHOOL
  BRANCH
  DEPARTMENT
}

enum CustomFeatureType {
  MENU_PAGE
  BUTTON_ACTION
  REPORT
  API_ACCESS
  HIDDEN_TOOL
}

enum AccessScope {
  GLOBAL
  DEPARTMENT
  USER_SPECIFIC
}

enum FeatureStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

enum MarksStatus {
  SUBMITTED
  LOCK_PENDING
  LOCKED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RequestType {
  EDIT_MARKS
  ACCESS_REQUEST
  CORRECTION_REQUEST
}

enum FileAssetStatus {
  UPLOADING
  READY
  FAILED
  ARCHIVED
}

enum ExamType {
  FORMATIVE
  SUMMATIVE
  QUARTERLY
  HALF_YEARLY
  ANNUAL
  UNIT_TEST
}

enum SubjectType {
  MAIN
  OPTIONAL
  CO_CURRICULAR
  LANGUAGE
}

// ─── M04 NEW ENUMS ────────────────────────────────────────────────────────────

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  HOLIDAY
  MEDICAL_LEAVE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentCategory {
  GENERAL
  OBC
  SC
  ST
  EWS
}

enum ParentRelation {
  FATHER
  MOTHER
  GUARDIAN
  OTHER
}

enum FeeFrequency {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  ANNUAL
  ONE_TIME
}

enum PaymentMode {
  CASH
  CHEQUE
  NEFT
  UPI
  DEMAND_DRAFT
}

enum InstallmentStatus {
  PENDING
  PAID
  OVERDUE
  WAIVED
  PARTIAL
}

enum ReportTemplate {
  CBSE_10_POINT
  ICSE_PERCENT
  STATE_BOARD_PERCENT
  CUSTOM
}

enum NoticeType {
  ACADEMIC
  EXAM
  FEE
  EVENT
  HOLIDAY
  GENERAL
  URGENT
}

enum NoticeAudience {
  ALL
  ADMIN_ONLY
  FACULTY
  PARENTS
  STUDENTS
  SPECIFIC_GRADES
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  IN_APP
}

enum NotificationStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

enum JobType {
  PDF_BATCH
  EXCEL_EXPORT
  BULK_EMAIL
  BULK_SMS
  FEE_INSTALLMENT_GENERATION
}

enum JobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

// ─── TENANT (SaaS root — every record belongs to one Tenant) ─────────────────

model Tenant {
  id                 String             @id @default(cuid())
  slug               String             @unique
  name               String
  board              SchoolBoard        @default(CBSE)
  medium             String             @default("English")
  subscriptionTier   SubscriptionTier   @default(STARTER)
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  trialEndsAt        DateTime?
  isActive           Boolean            @default(true)
  settings           Json?
  // M04 additions
  address            Json?
  phone              String?
  email              String?
  website            String?
  logoKey            String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Back-relations — Sprint 1 + 2
  config                   SchoolConfig?
  users                    User[]
  academicYears            AcademicYear[]
  terms                    Term[]
  grades                   Grade[]
  sections                 Section[]
  subjects                 Subject[]
  roles                    Role[]
  customFeatures           CustomFeature[]
  customFeatureAssignments CustomFeatureAssignment[]
  rbacLogs                 RBACLog[]
  departments              Department[]
  faculty                  Faculty[]
  classes                  Class[]
  students                 Student[]
  exams                    Exam[]
  marks                    Marks[]
  requests                 Request[]
  auditLogs                AuditLog[]
  fileAssets               FileAsset[]
  // Back-relations — M04
  parents                  Parent[]
  notices                  Notice[]
  feeCategories            FeeCategory[]
  feeStructures            FeeStructure[]
  feeAccounts              StudentFeeAccount[]
  feeInstallments          FeeInstallment[]
  feeCollections           FeeCollection[]
  receiptSequences         ReceiptSequence[]
  attendanceSessions       AttendanceSession[]
  reportCardConfigs        ReportCardConfig[]
  reportCards              ReportCard[]
  notificationLogs         NotificationLog[]
  jobQueues                JobQueue[]

  @@index([subscriptionStatus, isActive])
}

model SchoolConfig {
  id                     String   @id @default(cuid())
  schoolId               String   @unique
  gradingSystem          String   @default("TEN_POINT")
  workingDays            Int      @default(6)
  timezone               String   @default("Asia/Kolkata")
  academicYearStartMonth Int      @default(4)
  primaryColor           String?
  secondaryColor         String?
  logoKey                String?
  // M04 additions
  currentAcademicYearId  String?
  attendanceMinPercent   Decimal?
  lateFeeEnabled         Boolean  @default(false)
  lateFeeAmount          Decimal?
  lateFeeGraceDays       Int?
  whatsappEnabled        Boolean  @default(false)
  smsEnabled             Boolean  @default(false)
  emailEnabled           Boolean  @default(true)
  currency               String   @default("INR")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  school Tenant @relation(fields: [schoolId], references: [id], onDelete: Restrict)
}

// ─── USERS & AUTH ─────────────────────────────────────────────────────────────

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  name        String
  role        UserRole
  schoolId    String
  phone       String?
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  avatarUrl   String?
  // M04 addition: force password change on first login
  requiresPasswordChange Boolean @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  school Tenant @relation(fields: [schoolId], references: [id], onDelete: Restrict)

  faculty               Faculty?
  auditLogs             AuditLog[]
  requests              Request[]
  fileAssets            FileAsset[]
  roles                 RoleAssignment[]
  customFeatures        CustomFeatureAssignment[]
  createdRoles          Role[]
  createdCustomFeatures CustomFeature[]
  rbacLogs              RBACLog[]
  assignedRoles         RoleAssignment[]         @relation("AssignedByUser")
  assignedFeatures      CustomFeatureAssignment[] @relation("AssignedByFeature")
  acceptedFeatures      CustomFeatureAssignment[] @relation("AcceptedFeatures")
  departmentsHead       Department[]
  marksLocked           Marks[]
  // M04 back-relations
  parentProfile         Parent?                  @relation("ParentUser")
  markedAttendance      AttendanceSession[]      @relation("AttendanceMarkedBy")
  collectedFees         FeeCollection[]          @relation("FeeCollectedBy")
  voidedFees            FeeCollection[]          @relation("FeeVoidedBy")

  @@index([email])
  @@index([schoolId, role])
  @@index([schoolId, isActive])
}

// ─── RBAC ─────────────────────────────────────────────────────────────────────

model Role {
  id          String          @id @default(cuid())
  schoolId    String
  name        String
  description String?
  systemRole  SystemRole?
  scope       PermissionScope @default(SCHOOL)
  status      Boolean         @default(true)
  createdBy   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  school  Tenant @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  creator User   @relation(fields: [createdBy], references: [id], onDelete: Restrict)

  permissions              RolePermission[]
  userAssignments          RoleAssignment[]
  customFeatureAssignments CustomFeatureAssignment[] @relation("RoleCustomFeatures")

  @@unique([schoolId, name])
  @@index([schoolId, systemRole])
  @@index([schoolId, status])
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  module      String
  action      String
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@index([module])
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model RoleAssignment {
  id           String   @id @default(cuid())
  userId       String
  roleId       String
  schoolId     String
  departmentId String?
  assignedBy   String
  assignedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  department     Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  assignedByUser User        @relation("AssignedByUser", fields: [assignedBy], references: [id], onDelete: Restrict)

  @@unique([userId, roleId, schoolId, departmentId])
  @@index([userId, schoolId, departmentId])
  @@index([roleId, schoolId, departmentId])
  @@index([departmentId])
}

model CustomFeature {
  id          String            @id @default(cuid())
  schoolId    String
  name        String
  key         String
  module      String
  description String?
  type        CustomFeatureType @default(HIDDEN_TOOL)
  scope       AccessScope       @default(GLOBAL)
  status      FeatureStatus     @default(ACTIVE)
  createdBy   String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  school      Tenant                    @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  creator     User                      @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  assignments CustomFeatureAssignment[]

  @@unique([schoolId, key])
  @@index([schoolId, status])
  @@index([module])
}

model CustomFeatureAssignment {
  id                 String    @id @default(cuid())
  schoolId           String
  featureId          String
  roleId             String?
  userId             String?
  departmentId       String?
  startDate          DateTime  @default(now())
  expiryDate         DateTime?
  requiresAcceptance Boolean   @default(false)
  acceptedAt         DateTime?
  acceptedBy         String?
  declinedAt         DateTime?
  declinedBy         String?
  declineReason      String?
  assignedBy         String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  school         Tenant        @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  feature        CustomFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)
  role           Role?         @relation("RoleCustomFeatures", fields: [roleId], references: [id], onDelete: Cascade)
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedByUser User          @relation("AssignedByFeature", fields: [assignedBy], references: [id], onDelete: Restrict)
  acceptedByUser User?         @relation("AcceptedFeatures", fields: [acceptedBy], references: [id], onDelete: SetNull)

  @@unique([featureId, roleId, userId, schoolId])
  @@index([schoolId, featureId])
  @@index([userId, schoolId])
  @@index([roleId, schoolId])
  @@index([expiryDate])
}

model RBACLog {
  id         String   @id @default(cuid())
  schoolId   String
  actorId    String
  action     String
  targetType String
  targetId   String
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  school Tenant @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  actor  User   @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([schoolId, action, createdAt])
  @@index([schoolId, targetType, targetId])
  @@index([actorId])
}

// ─── DEPARTMENTS & FACULTY ────────────────────────────────────────────────────

model Department {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  code      String?
  headId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school Tenant @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  head   User?  @relation(fields: [headId], references: [id], onDelete: SetNull)

  faculty         FacultyDepartment[]
  classes         Class[]
  exams           Exam[]
  roleAssignments RoleAssignment[]
  subjects        Subject[]

  @@unique([schoolId, code])
  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([headId])
}

model Faculty {
  id        String   @id @default(cuid())
  userId    String   @unique
  schoolId  String
  createdAt DateTime @default(now())

  school      Tenant              @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  user        User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  departments FacultyDepartment[]
  classes     Class[]

  @@index([schoolId])
}

model FacultyDepartment {
  id           String   @id @default(cuid())
  facultyId    String
  departmentId String
  primary      Boolean  @default(false)
  createdAt    DateTime @default(now())

  faculty    Faculty    @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([facultyId, departmentId])
  @@index([departmentId])
}

// ─── CLASSES & STUDENTS ───────────────────────────────────────────────────────

model Class {
  id           String   @id @default(cuid())
  schoolId     String
  departmentId String
  name         String
  grade        Int
  section      String
  subject      String
  facultyId    String
  // M04 additions: FK references to academic structure models
  gradeId      String?
  sectionId    String?
  subjectId    String?
  academicYearId String?
  createdAt    DateTime @default(now())

  school       Tenant       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  faculty      Faculty      @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  gradeRef     Grade?       @relation("ClassGrade", fields: [gradeId], references: [id], onDelete: SetNull)
  sectionRef   Section?     @relation("ClassSection", fields: [sectionId], references: [id], onDelete: SetNull)
  subjectRef   Subject?     @relation("ClassSubject", fields: [subjectId], references: [id], onDelete: SetNull)
  academicYear AcademicYear? @relation("ClassAcademicYear", fields: [academicYearId], references: [id], onDelete: SetNull)

  students          ClassStudent[]
  marks             Marks[]
  exams             Exam[]
  attendanceSessions AttendanceSession[]

  @@unique([schoolId, departmentId, grade, section, subject])
  @@index([schoolId, departmentId])
  @@index([schoolId, grade, section])
  @@index([departmentId, facultyId])
  @@index([schoolId, gradeId, sectionId])
  @@index([academicYearId])
}

model Student {
  id        String   @id @default(cuid())
  schoolId  String
  email     String
  name      String
  rollNo    String
  // M04 SIS additions (all optional for backward compat with existing records)
  admissionNo    String?
  admissionDate  DateTime?
  dateOfBirth    DateTime?
  gender         Gender?
  category       StudentCategory @default(GENERAL)
  bloodGroup     String?
  phone          String?
  address        Json?
  photo          String?
  religion       String?
  motherTongue   String?
  previousSchool String?
  isActive       Boolean  @default(true)
  currentGradeId  String?
  currentSectionId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  Tenant         @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  classes ClassStudent[]
  marks   Marks[]
  // M04 back-relations
  parents          ParentStudent[]
  feeAccounts      StudentFeeAccount[]
  feeInstallments  FeeInstallment[]
  reportCards      ReportCard[]
  attendanceRecords AttendanceRecord[]

  @@unique([schoolId, email])
  @@unique([schoolId, admissionNo])
  @@index([schoolId])
  @@index([schoolId, name])
  @@index([schoolId, isActive])
  @@index([schoolId, currentGradeId, currentSectionId])
}

model ClassStudent {
  id         String   @id @default(cuid())
  classId    String
  studentId  String
  enrolledAt DateTime @default(now())

  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
}

// ─── EXAMS & MARKS ────────────────────────────────────────────────────────────

model Exam {
  id           String    @id @default(cuid())
  schoolId     String
  departmentId String
  classId      String?
  name         String
  maxMarks     Int
  startDate    DateTime
  endDate      DateTime?
  createdAt    DateTime  @default(now())

  school     Tenant     @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  class      Class?     @relation(fields: [classId], references: [id], onDelete: Cascade)
  marks      Marks[]

  @@unique([schoolId, departmentId, name, startDate])
  @@index([schoolId, departmentId])
  @@index([departmentId, classId])
  @@index([schoolId, startDate])
}

model Marks {
  id              String      @id @default(cuid())
  schoolId        String
  examId          String
  classId         String
  studentId       String
  value           String
  status          MarksStatus @default(SUBMITTED)
  lockRequestedAt DateTime?
  lockedAt        DateTime?
  lockedBy        String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  school  Tenant       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  exam    Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  class   Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  locker  User?        @relation(fields: [lockedBy], references: [id], onDelete: SetNull)
  history MarksHistory[]

  @@unique([examId, studentId])
  @@index([schoolId, examId, classId, status])
  @@index([classId, examId, status])
  @@index([lockedBy])
}

model MarksHistory {
  id        String      @id @default(cuid())
  marksId   String
  value     String
  status    MarksStatus
  changedBy String
  reason    String?
  createdAt DateTime    @default(now())

  marks Marks @relation(fields: [marksId], references: [id], onDelete: Restrict)

  @@index([marksId, createdAt])
}

// ─── REQUESTS ─────────────────────────────────────────────────────────────────

model Request {
  id          String        @id @default(cuid())
  schoolId    String
  userId      String
  type        RequestType
  status      RequestStatus @default(PENDING)
  marksId     String?
  reason      String
  response    String?
  respondedBy String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  school Tenant @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([schoolId, status, createdAt])
}

// ─── AUDIT ────────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  schoolId  String
  userId    String
  action    String
  entity    String
  entityId  String
  changes   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  school Tenant @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([schoolId, action, entityId, createdAt])
  @@index([schoolId, createdAt])
}

// ─── ACADEMIC STRUCTURE (M03) ─────────────────────────────────────────────────

model AcademicYear {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  isLocked  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school Tenant @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  terms  Term[]
  // M04 back-relations
  classes        Class[]           @relation("ClassAcademicYear")
  feeStructures  FeeStructure[]
  feeAccounts    StudentFeeAccount[]
  feeInstallments FeeInstallment[]

  @@unique([schoolId, name])
  @@index([schoolId, isCurrent])
}

model Term {
  id             String   @id @default(cuid())
  schoolId       String
  academicYearId String
  name           String
  examType       ExamType
  order          Int
  weightage      Int
  startDate      DateTime?
  endDate        DateTime?
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  school       Tenant       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  // M04 back-relations
  reportCards   ReportCard[]
  reportConfigs ReportCardConfig[]

  @@unique([schoolId, academicYearId, name])
  @@index([schoolId, academicYearId, order])
}

model Grade {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  level     Int
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school Tenant @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  // M04 back-relations
  classes       Class[]           @relation("ClassGrade")
  feeStructures FeeStructure[]
  reportConfigs ReportCardConfig[]

  @@unique([schoolId, level])
  @@unique([schoolId, name])
  @@index([schoolId, level])
}

model Section {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  Tenant  @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  // M04 back-relation
  classes Class[] @relation("ClassSection")

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Subject {
  id           String      @id @default(cuid())
  schoolId     String
  name         String
  code         String
  subjectType  SubjectType @default(MAIN)
  departmentId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  school     Tenant      @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  // M04 back-relation
  classes    Class[]     @relation("ClassSubject")

  @@unique([schoolId, code])
  @@unique([schoolId, name])
  @@index([schoolId, subjectType])
  @@index([departmentId])
}

// ─── FILE ASSETS ──────────────────────────────────────────────────────────────

model FileAsset {
  id          String          @id @default(cuid())
  schoolId    String
  ownerId     String
  bucket      String
  storageKey  String
  storagePath String?
  fileName    String
  fileType    String
  sizeBytes   Int
  status      FileAssetStatus @default(UPLOADING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  school Tenant @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  owner  User   @relation(fields: [ownerId], references: [id], onDelete: Restrict)

  @@unique([bucket, storageKey])
  @@index([schoolId, ownerId, createdAt])
  @@index([schoolId, status, createdAt])
  @@index([bucket, storageKey])
}

// ─── M04: PARENT MANAGEMENT ───────────────────────────────────────────────────

model Parent {
  id             String   @id @default(cuid())
  schoolId       String
  userId         String?  @unique
  fatherName     String?
  motherName     String?
  guardianName   String?
  primaryPhone   String
  secondaryPhone String?
  email          String?
  occupation     String?
  address        Json?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  school   Tenant  @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  user     User?   @relation("ParentUser", fields: [userId], references: [id], onDelete: SetNull)
  children ParentStudent[]

  @@index([schoolId])
  @@index([schoolId, primaryPhone])
}

model ParentStudent {
  id        String         @id @default(cuid())
  parentId  String
  studentId String
  relation  ParentRelation
  isPrimary Boolean        @default(false)
  createdAt DateTime       @default(now())

  parent  Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@index([studentId])
}

// ─── M04: ATTENDANCE ──────────────────────────────────────────────────────────

model AttendanceSession {
  id             String   @id @default(cuid())
  schoolId       String
  classId        String
  academicYearId String
  date           DateTime @db.Date
  markedBy       String
  markedAt       DateTime @default(now())
  isFinalized    Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  school    Tenant  @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  marker    User    @relation("AttendanceMarkedBy", fields: [markedBy], references: [id], onDelete: Restrict)
  records   AttendanceRecord[]

  @@unique([classId, date])
  @@index([schoolId, date])
  @@index([schoolId, classId, academicYearId])
}

model AttendanceRecord {
  id        String           @id @default(cuid())
  sessionId String
  studentId String
  status    AttendanceStatus
  remark    String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  session AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([studentId, sessionId])
}

// ─── M04: REPORT CARDS ────────────────────────────────────────────────────────

model ReportCardConfig {
  id             String         @id @default(cuid())
  schoolId       String
  academicYearId String
  termId         String
  gradeId        String
  template       ReportTemplate @default(CBSE_10_POINT)
  showGrade      Boolean        @default(true)
  showRank       Boolean        @default(false)
  showAttendance Boolean        @default(true)
  showRemarks    Boolean        @default(true)
  customConfig   Json?
  isPublished    Boolean        @default(false)
  publishedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  school      Tenant       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  term        Term         @relation(fields: [termId], references: [id], onDelete: Cascade)
  grade       Grade        @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  reportCards ReportCard[]

  @@unique([schoolId, academicYearId, termId, gradeId])
  @@index([schoolId, termId])
}

model ReportCard {
  id             String   @id @default(cuid())
  schoolId       String
  studentId      String
  academicYearId String
  termId         String
  configId       String
  totalMarks     Decimal?
  maxMarks       Decimal?
  percentage     Decimal?
  grade          String?
  rank           Int?
  attendance     Json?
  remarks        String?
  isGenerated    Boolean  @default(false)
  generatedAt    DateTime?
  pdfKey         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  school  Tenant           @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  student Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term    Term             @relation(fields: [termId], references: [id], onDelete: Cascade)
  config  ReportCardConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([studentId, termId])
  @@index([schoolId, termId])
  @@index([schoolId, studentId])
}

// ─── M04: FEE MANAGEMENT ─────────────────────────────────────────────────────

model FeeCategory {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  code        String?
  isRecurring Boolean  @default(true)
  isTaxable   Boolean  @default(false)
  taxRate     Decimal?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school       Tenant           @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  structures   FeeStructure[]
  installments FeeInstallment[]

  @@unique([schoolId, code])
  @@index([schoolId])
}

model FeeStructure {
  id             String       @id @default(cuid())
  schoolId       String
  academicYearId String
  gradeId        String
  categoryId     String
  amount         Decimal
  frequency      FeeFrequency
  dueDay         Int?
  isOptional     Boolean      @default(false)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  school       Tenant       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  grade        Grade        @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  category     FeeCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@unique([academicYearId, gradeId, categoryId])
  @@index([schoolId, academicYearId])
}

model StudentFeeAccount {
  id             String   @id @default(cuid())
  schoolId       String
  studentId      String
  academicYearId String
  totalAmount    Decimal  @default(0)
  totalPaid      Decimal  @default(0)
  totalDue       Decimal  @default(0)
  concession     Decimal  @default(0)
  concessionNote String?
  lastUpdatedAt  DateTime @updatedAt

  school       Tenant       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYearId])
  @@index([schoolId, academicYearId])
}

model FeeInstallment {
  id             String            @id @default(cuid())
  schoolId       String
  studentId      String
  academicYearId String
  categoryId     String
  amount         Decimal
  dueDate        DateTime
  status         InstallmentStatus @default(PENDING)
  paidAt         DateTime?
  paidAmount     Decimal?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  school       Tenant       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  category     FeeCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  collections  FeeCollectionInstallment[]

  @@index([schoolId, studentId, academicYearId])
  @@index([dueDate, status])
  @@index([schoolId, academicYearId, status])
}

model ReceiptSequence {
  id             String @id @default(cuid())
  schoolId       String
  academicYearId String
  prefix         String @default("RCP")
  lastSeq        Int    @default(0)

  school Tenant @relation(fields: [schoolId], references: [id], onDelete: Restrict)

  @@unique([schoolId, academicYearId])
}

model FeeCollection {
  id             String      @id @default(cuid())
  schoolId       String
  studentId      String
  academicYearId String
  receiptNo      String      @unique
  receiptDate    DateTime
  amount         Decimal
  paymentMode    PaymentMode
  chequeNo       String?
  bankName       String?
  transactionRef String?
  collectedBy    String
  notes          String?
  isVoided       Boolean     @default(false)
  voidedBy       String?
  voidedAt       DateTime?
  voidReason     String?
  createdAt      DateTime    @default(now())

  school      Tenant   @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  collector   User     @relation("FeeCollectedBy", fields: [collectedBy], references: [id], onDelete: Restrict)
  voider      User?    @relation("FeeVoidedBy", fields: [voidedBy], references: [id], onDelete: SetNull)
  installments FeeCollectionInstallment[]

  @@index([schoolId, studentId])
  @@index([schoolId, receiptDate])
  @@index([receiptNo])
}

model FeeCollectionInstallment {
  id            String  @id @default(cuid())
  collectionId  String
  installmentId String
  amountApplied Decimal

  collection  FeeCollection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  installment FeeInstallment @relation(fields: [installmentId], references: [id], onDelete: Restrict)

  @@unique([collectionId, installmentId])
  @@index([installmentId])
}

// ─── M04: NOTICES ─────────────────────────────────────────────────────────────

model Notice {
  id             String         @id @default(cuid())
  schoolId       String
  title          String
  body           String         @db.Text
  type           NoticeType     @default(GENERAL)
  priority       Int            @default(1)
  targetAudience NoticeAudience @default(ALL)
  gradeIds       String[]
  isPublished    Boolean        @default(false)
  publishedAt    DateTime?
  expiresAt      DateTime?
  attachmentKey  String?
  createdBy      String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  school        Tenant            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  notifications NotificationLog[]

  @@index([schoolId, isPublished, publishedAt])
  @@index([schoolId, type])
  @@index([expiresAt])
}

model NotificationLog {
  id          String              @id @default(cuid())
  schoolId    String
  noticeId    String?
  channel     NotificationChannel
  recipientId String
  status      NotificationStatus  @default(QUEUED)
  sentAt      DateTime?
  deliveredAt DateTime?
  error       String?
  provider    String?
  providerRef String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  school Tenant  @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  notice Notice? @relation(fields: [noticeId], references: [id], onDelete: SetNull)

  @@index([schoolId, channel, status])
  @@index([noticeId])
  @@index([recipientId])
}

// ─── M04: BACKGROUND JOBS ────────────────────────────────────────────────────

model JobQueue {
  id          String    @id @default(cuid())
  schoolId    String
  type        JobType
  status      JobStatus @default(PENDING)
  payload     Json
  result      Json?
  error       String?
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  school Tenant @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([status, createdAt])
}
