{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/classes/[id]",
      "regex": "^/api/classes/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/classes/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/marks/[id]/history",
      "regex": "^/api/marks/([^/]+?)/history(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/marks/(?<nxtPid>[^/]+?)/history(?:/)?$"
    },
    {
      "page": "/api/requests/[id]/approve",
      "regex": "^/api/requests/([^/]+?)/approve(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/requests/(?<nxtPid>[^/]+?)/approve(?:/)?$"
    },
    {
      "page": "/api/requests/[id]/reject",
      "regex": "^/api/requests/([^/]+?)/reject(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/requests/(?<nxtPid>[^/]+?)/reject(?:/)?$"
    },
    {
      "page": "/api/v1/classes/[id]",
      "regex": "^/api/v1/classes/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/v1/classes/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/v1/classes/[id]/students",
      "regex": "^/api/v1/classes/([^/]+?)/students(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/v1/classes/(?<nxtPid>[^/]+?)/students(?:/)?$"
    },
    {
      "page": "/api/v1/requests/[id]",
      "regex": "^/api/v1/requests/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/v1/requests/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
      "page": "/admin/classes",
      "regex": "^/admin/classes(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/classes(?:/)?$"
    },
    {
      "page": "/admin/logs",
