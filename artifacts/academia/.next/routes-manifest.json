      "routeKeys": {},
      "namedRegex": "^/admin/logs(?:/)?$"
    },
    {
      "page": "/admin/requests",
      "regex": "^/admin/requests(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/requests(?:/)?$"
    },
    {
      "page": "/admin/roles",
      "regex": "^/admin/roles(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/roles(?:/)?$"
    },
    {
      "page": "/admin/students",
      "regex": "^/admin/students(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/students(?:/)?$"
    },
    {
      "page": "/auth/login",
      "regex": "^/auth/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/auth/login(?:/)?$"
    },
    {
      "page": "/faculty",
      "regex": "^/faculty(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/faculty(?:/)?$"
    },
    {
      "page": "/faculty/classes",
      "regex": "^/faculty/classes(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/faculty/classes(?:/)?$"
    },
    {
      "page": "/faculty/requests",
      "regex": "^/faculty/requests(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/faculty/requests(?:/)?$"
    }
