# ─── Database ────────────────────────────────────────────────────────────────
# Supabase pooled connection (PgBouncer) — used at runtime by Prisma client
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"

# Supabase direct connection — used for prisma migrate deploy (bypasses PgBouncer)
# Format: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# 32+ random bytes, base64 or hex. Generate: openssl rand -base64 32
AUTH_SECRET="your-very-long-random-secret-here"

# ─── Supabase (kept for Supabase SDK / storage integration) ──────────────────
# Get from: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# ─── Optional (required only when feature is enabled) ─────────────────────────
# Email delivery via Resend (notices, password reset)
# RESEND_API_KEY="re_..."
# FROM_EMAIL="noreply@yourdomain.com"

# ─── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV="development"
