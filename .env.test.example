# Test Environment Configuration
# Copy this to .env.test.local and fill in your test database credentials

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/academia_test
DIRECT_URL=postgresql://postgres:password@localhost:5432/academia_test

# Supabase (Test Project)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# Auth
AUTH_SECRET=test_secret_minimum_32_characters_long_for_security

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=test

# Logging
PRISMA_QUERY_LOG=false

# Test Configuration
TEST_TIMEOUT_MS=30000
TEST_DATABASE_CLEANUP=true
